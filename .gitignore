# ── Build outputs (regenerable: tools/build_native_acad.ps1 + dotnet build) ──
bin/
obj/
obj-crx/
*.pdb
*.ilk
*.exp
*.lib
*.idb
*.obj
*.pch
*.ipdb
*.iobj
*.tlog
*.lastbuildstate
*.user

# ── Large, regenerable run + staging evidence ──
runs/
staging/
ErrorReports/

# ── Caches / generated indexes ──
.pytest_cache/
__pycache__/
*.pyc
graphify-out/

# ── CAD binaries: originals must never be committed; staged copies regenerate ──
*.dwg
*.dxf
*.dwt
*.dwl
*.dwl2
*.bak

# ── EXCEPTION: tracked native test fixtures ───────────────────────────────────
# A git worktree checks out only TRACKED files, so the staging/ DWG churn (above)
# never reaches a worktree — which blocks native ObjectARX/DBX runtime smokes in
# isolated ticket worktrees. We therefore track a small, CLEAN, canonical DWG (and
# any future fixtures) under tests/fixtures/ ONLY. Everything else under staging/,
# runs/, and every other *.dwg stays ignored. Originals are never mutated; this is
# a read-only fixture copy.
!tests/fixtures/*.dwg
!tests/fixtures/*.dxf

# F10 fixture_foundry.py golden per-kind fixtures (Lane-A create -> re-inspect
# -> commit; tools/fixture_foundry.py). Same reasoning as tests/fixtures/
# above -- these are checked-in, read-only evidence, not staging churn.
!fixtures/kinds/*.dwg
*.sv$

# ── Secrets (defense-in-depth; none currently present) ──
.env
.env.*
*.env
*.pem
*.p12
*.key
*credential*
*secret*

# ── Handoff bundles (regenerable zips; index.md stays tracked) ──
handoff/zip/*.zip

# ── Build-wave / session evidence scratch (not part of the distributable) ──
docs/CADOS_ClaudeCode_Handoff_Report.md
reports/M08_PARALLEL_BUILD_BOARD.*
reports/WAVE4*
reports/remaining_after_wave*
reports/merge/MERGE_WAVE4*
reports/merge/MAIN_DIRTY_STATE_*
reports/tickets/WAVE4*

# ── OS noise ──
Thumbs.db
desktop.ini
.DS_Store

+      << ",\"cloned\":" << (cloned ? "true" : "false")
+      << ",\"clone_handle\":" << (cloneHandle.empty() ? std::string("null") : njsonStr(cloneHandle))
+      << ",\"staged_rolled_back\":true,\"errorstatus\":" << static_cast<int>(es)
+      << "},\"status\":\"" << (cloned ? "ok" : "error") << "\"}";
+    return true;
+}

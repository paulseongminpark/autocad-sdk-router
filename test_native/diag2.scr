(vl-load-com)
(setvar "SECURELOAD" 0)
(setvar "TRUSTEDPATHS" "D:\\dev\\99_tools\\autocad-sdk-router\\src\\Ariadne.AcadNative\\bin\\x64\\Release")
(setq r (vl-catch-all-apply 'arxload (list "D:/dev/99_tools/autocad-sdk-router/src/Ariadne.AcadNative/bin/x64/Release/Ariadne.AcadNative.arx")))
(setq f (open "D:/dev/99_tools/autocad-sdk-router/test_native/diag2.txt" "w"))
(if (vl-catch-all-error-p r)
  (write-line (strcat "ARXLOAD_ERROR: " (vl-catch-all-error-message r)) f)
  (write-line (strcat "ARXLOAD_OK: " (vl-princ-to-string r)) f))
(write-line "---LOADED---" f)
(foreach m (arx) (write-line m f))
(close f)
(princ)

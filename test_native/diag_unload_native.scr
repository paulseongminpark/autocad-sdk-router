(vl-load-com)
(setq r1 (vl-catch-all-apply 'arxunload (list "ariadne.acadnative.arx")))
(setq r2 (vl-catch-all-apply 'arxunload (list "ariadne.acadnativedbx.dbx")))
(setq f (open "D:/dev/99_tools/autocad-sdk-router/test_native/diag_unload_native.txt" "w"))
(if (vl-catch-all-error-p r1)
  (write-line (strcat "ARXUNLOAD_ERROR: " (vl-catch-all-error-message r1)) f)
  (write-line (strcat "ARXUNLOAD_OK: " (vl-princ-to-string r1)) f))
(if (vl-catch-all-error-p r2)
  (write-line (strcat "DBXUNLOAD_ERROR: " (vl-catch-all-error-message r2)) f)
  (write-line (strcat "DBXUNLOAD_OK: " (vl-princ-to-string r2)) f))
(write-line "---LOADED---" f)
(foreach m (arx) (write-line m f))
(close f)
(princ)

(vl-load-com)
(setvar "SECURELOAD" 0)
(setvar "FILEDIA" 0)
(setvar "TRUSTEDPATHS" "D:\\dev\\99_tools\\autocad-sdk-router\\src\\Ariadne.AcadNative\\bin\\x64\\Release")
(setq dbx-r (vl-catch-all-apply 'arxload (list "D:/dev/99_tools/autocad-sdk-router/src/Ariadne.AcadNative/bin/x64/Release/Ariadne.AcadNativeDbx.dbx")))
(setq arx-r (vl-catch-all-apply 'arxload (list "D:/dev/99_tools/autocad-sdk-router/src/Ariadne.AcadNative/bin/x64/Release/Ariadne.AcadNative.arx")))
(setq f (open "D:/dev/99_tools/autocad-sdk-router/test_native/diag_arx_fullacad.txt" "w"))
(if (vl-catch-all-error-p dbx-r)
  (write-line (strcat "DBXLOAD_ERROR: " (vl-catch-all-error-message dbx-r)) f)
  (write-line (strcat "DBXLOAD_OK: " (vl-princ-to-string dbx-r)) f))
(if (vl-catch-all-error-p arx-r)
  (write-line (strcat "ARXLOAD_ERROR: " (vl-catch-all-error-message arx-r)) f)
  (write-line (strcat "ARXLOAD_OK: " (vl-princ-to-string arx-r)) f))
(write-line "---LOADED---" f)
(foreach m (arx) (write-line m f))
(close f)
(princ)

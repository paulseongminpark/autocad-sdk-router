(vl-load-com)
(setvar "SECURELOAD" 0)
(setq r (vl-catch-all-apply 'arxload (list "C:/ObjectARX 2027/samples/misc/fact_dg/x64/Release/fact.arx")))
(setq f (open "D:/dev/99_tools/autocad-sdk-router/test_native/diag3.txt" "w"))
(if (vl-catch-all-error-p r)
  (write-line "FACT_LOAD: FAILED" f)
  (write-line "FACT_LOAD: OK" f))
(write-line "---LOADED---" f)
(foreach m (arx) (write-line m f))
(close f)
(princ)

      "headless": true,
      "attended": false,
      "doc_manager": false,
      "can_write_original": false,
      "can_write_staged": true,
      "notes": "Hostless DBX database read/write inside Core Console. No editor, no active document. Cheapest host for pure DB work."
    },
    "core_console": {
      "binary": "accoreconsole.exe (AutoCAD 2027)",

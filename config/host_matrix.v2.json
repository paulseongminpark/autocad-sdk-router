      "headless": true,
      "attended": false,
      "doc_manager": false,
      "can_write_original": true,
      "can_write_staged": true,
      "notes": "Headless command/script automation + .crx native shell + AutoLISP/.scr. No UI. Document write via QSAVE (never Database.SaveAs) per original-DWG safety contract."
    },
    "native_arx": {
      "binary": "in-process ObjectARX (.arx/.crx) ARIADNE_NATIVE_JOB dispatcher",
      "headless": true,
      "attended": false,
      "doc_manager": true,
      "can_write_original": true,
      "can_write_staged": true,
      "notes": "Native ARX shell loads the DBX core then registers the ARIADNE_NATIVE_JOB session-modal command. Takes an AriadneDocumentWriteLock at entry. Runs under Core Console (headless) or full AutoCAD."
    },
    "managed": {
      "binary": "managed .NET host (acmgd/acdbmgd/accoremgd) ARIADNE_CAD_JOB CommandMethod",
      "headless": true,
      "attended": false,
      "doc_manager": true,
      "can_write_original": true,
      "can_write_staged": true,
      "notes": "Managed .NET CadJobRunner. Hosts the 1 managed wired op (inspect.database.summary). Locks the current document before write ops; persists via router QSAVE not Database.SaveAs."
